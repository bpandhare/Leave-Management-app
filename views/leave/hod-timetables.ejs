<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Faculty Timetables - Leave Management System</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .header-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
        }
        .faculty-card {
            border: none;
            border-radius: 15px;
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
            cursor: pointer;
        }
        .faculty-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }
        .faculty-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 10px 10px 0 0;
            padding: 15px;
        }
        .timetable-item {
            border-left: 5px solid #667eea;
            padding: 15px;
            margin-bottom: 10px;
            background: #f9f9f9;
            border-radius: 8px;
        }
        .timetable-item:hover {
            background: #f0f0f0;
        }
        .navbar-brand {
            font-weight: 700;
        }
        .user-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }
        .faculty-avatar {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 1.2rem;
        }
        .badge-uploaded {
            font-size: 0.8rem;
            padding: 0.4rem 0.8rem;
        }
        .no-data-message {
            text-align: center;
            padding: 40px 20px;
        }
        .filters {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
        .search-box {
            border-radius: 10px;
            border: 1px solid #ddd;
        }
    </style>
</head>
<body class="bg-light">
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="fas fa-calendar-alt me-2"></i>
                LeaveManager
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="fas fa-tachometer-alt me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/timetable/hod">
                            <i class="fas fa-table me-1"></i>Faculty Timetables
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/leave/applications">
                            <i class="fas fa-check-circle me-1"></i>Leave Approvals
                        </a>
                    </li>
                </ul>
                
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                            <div class="user-avatar me-2">
                                <%= user.name ? user.name.charAt(0).toUpperCase() : user.username.charAt(0).toUpperCase() %>
                            </div>
                            <%= user.username %>
                        </a>
                        <ul class="dropdown-menu">
                            <li><span class="dropdown-item-text">
                                <small class="text-muted">Signed in as</small><br>
                                <strong><%= user.role %></strong>
                            </span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form method="POST" action="/auth/logout" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fas fa-sign-out-alt me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        <!-- Alert Messages -->
        <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i><%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- Header Section -->
        <div class="header-section">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="mb-2"><i class="fas fa-table me-2"></i>Faculty Weekly Timetables</h1>
                    <p class="mb-0">View and manage all faculty timetables in your department</p>
                </div>
                <div class="col-md-4 text-end">
                    <div class="badge bg-light text-dark badge-uploaded">
                        <i class="fas fa-users me-1"></i>
                        <span id="facultyCount">Loading...</span> Faculty Members
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters">
            <div class="row">
                <div class="col-md-6">
                    <input type="text" class="form-control search-box" id="searchInput" placeholder="Search faculty by name or email...">
                </div>
                <div class="col-md-6">
                    <select class="form-select" id="sortBy">
                        <option value="name">Sort by Name</option>
                        <option value="recent">Sort by Recent Upload</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Faculty Timetables Grid -->
        <div class="row" id="facultyTimetablesContainer">
            <div class="col-12 text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3 text-muted">Loading faculty timetables...</p>
            </div>
        </div>
    </div>

    <!-- View Timetables Modal -->
    <div class="modal fade" id="viewTimetablesModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="modalTitle">Faculty Timetables</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="timetablesListContent">
                    <!-- Content will be loaded dynamically -->
                </div>
            </div>
        </div>
    </div>

    <script src="/js/bootstrap.bundle.min.js"></script>
    <script>
        let allFacultyData = [];

        // Load all faculty timetables
        async function loadAllFacultyTimetables() {
            try {
                const response = await fetch('/timetable/api/hod/all-faculty-timetables');
                const result = await response.json();

                if (result.success) {
                    allFacultyData = result.timetables;
                    document.getElementById('facultyCount').textContent = result.timetables.length;
                    renderFacultyCards();
                } else {
                    displayNoData();
                }
            } catch (error) {
                console.error('Error loading faculty timetables:', error);
                displayNoData();
            }
        }

        function renderFacultyCards() {
            if (allFacultyData.length === 0) {
                displayNoData();
                return;
            }

            let html = '';
            allFacultyData.forEach(item => {
                const faculty = item.faculty;
                const timetable = item.latestTimetable;
                const startDate = timetable ? new Date(timetable.week.startDate).toLocaleDateString('en-IN') : 'N/A';
                const endDate = timetable ? new Date(timetable.week.endDate).toLocaleDateString('en-IN') : 'N/A';

                html += `
                    <div class="col-md-6 col-lg-4 mb-3">
                        <div class="card faculty-card shadow-sm h-100">
                            <div class="faculty-header">
                                <div class="d-flex align-items-center">
                                    <div class="faculty-avatar me-3">
                                        ${faculty.username.charAt(0).toUpperCase()}
                                    </div>
                                    <div>
                                        <h6 class="mb-0">${faculty.username}</h6>
                                        <small>${faculty.email}</small>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                ${timetable ? `
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <h6 class="card-title mb-1">Latest Timetable</h6>
                                            <p class="small text-muted mb-0">
                                                <i class="fas fa-calendar-alt me-1"></i>
                                                ${startDate} to ${endDate}
                                            </p>
                                        </div>
                                        <span class="badge bg-success">Uploaded</span>
                                    </div>
                                    <div class="d-grid gap-2">
                                        <a href="/timetable/download/${timetable._id}" class="btn btn-sm btn-primary">
                                            <i class="fas fa-download me-1"></i>Download
                                        </a>
                                        <button class="btn btn-sm btn-outline-secondary" onclick="viewFacultyTimetables('${faculty._id}', '${faculty.username}')">
                                            <i class="fas fa-history me-1"></i>View History
                                        </button>
                                    </div>
                                ` : `
                                    <div class="text-center py-3">
                                        <i class="fas fa-inbox text-muted fa-2x mb-2"></i>
                                        <p class="text-muted small">No timetable uploaded</p>
                                    </div>
                                `}
                            </div>
                        </div>
                    </div>
                `;
            });

            document.getElementById('facultyTimetablesContainer').innerHTML = html;
        }

        function displayNoData() {
            document.getElementById('facultyTimetablesContainer').innerHTML = `
                <div class="col-12">
                    <div class="no-data-message">
                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                        <p class="text-muted">No faculty timetables found</p>
                    </div>
                </div>
            `;
        }

        // View all timetables for a faculty
        async function viewFacultyTimetables(facultyId, facultyName) {
            try {
                const response = await fetch(`/timetable/api/hod/faculty/${facultyId}`);
                const result = await response.json();

                if (result.success && result.timetables.length > 0) {
                    let html = '';
                    result.timetables.forEach(timetable => {
                        const startDate = new Date(timetable.week.startDate).toLocaleDateString('en-IN');
                        const endDate = new Date(timetable.week.endDate).toLocaleDateString('en-IN');

                        html += `
                            <div class="timetable-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">
                                            <i class="fas fa-calendar-alt me-2 text-primary"></i>
                                            ${startDate} to ${endDate}
                                        </h6>
                                        <small class="text-muted">Uploaded: ${new Date(timetable.createdAt).toLocaleDateString('en-IN')}</small>
                                    </div>
                                    <a href="/timetable/download/${timetable._id}" class="btn btn-sm btn-primary">
                                        <i class="fas fa-download me-1"></i>Download
                                    </a>
                                </div>
                            </div>
                        `;
                    });

                    document.getElementById('modalTitle').textContent = `${facultyName}'s Timetables`;
                    document.getElementById('timetablesListContent').innerHTML = html;
                    new bootstrap.Modal(document.getElementById('viewTimetablesModal')).show();
                } else {
                    alert('No timetables found for this faculty');
                }
            } catch (error) {
                console.error('Error loading faculty timetables:', error);
                alert('Error loading timetables');
            }
        }

        // Search functionality
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const filtered = allFacultyData.filter(item => 
                item.faculty.username.toLowerCase().includes(searchTerm) ||
                item.faculty.email.toLowerCase().includes(searchTerm)
            );
            
            // Update display
            if (filtered.length === 0) {
                document.getElementById('facultyTimetablesContainer').innerHTML = `
                    <div class="col-12">
                        <div class="no-data-message">
                            <i class="fas fa-search text-muted fa-2x mb-3"></i>
                            <p class="text-muted">No faculty found matching your search</p>
                        </div>
                    </div>
                `;
            } else {
                allFacultyData = filtered;
                renderFacultyCards();
                allFacultyData = result.timetables; // Reset for next search
                loadAllFacultyTimetables();
            }
        });

        // Load timetables on page load
        document.addEventListener('DOMContentLoaded', loadAllFacultyTimetables);
    </script>
</body>
</html>
