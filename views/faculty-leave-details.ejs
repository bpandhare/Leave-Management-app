<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" integrity="sha512-+Soa9V5Ai+8EjaPqkKXDTS7s2i5Qv8f2QZII3JIu8Q56q/bU4NfTr+/+8YAfcFne9xQnT84x0MlI2uN5HuzXbw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        body {
            background: #f8f9fa;
            color: #343a40;
        }
        .faculty-card {
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
            border: none;
            border-radius: 1rem;
            background: #ffffff;
        }
        .faculty-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
        }
        .status-badge {
            padding: 0.375rem 0.85rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
        }
        .status-good { background-color: #d1fae5; color: #065f46; }
        .status-low { background-color: #fef3c7; color: #92400e; }
        .status-exhausted { background-color: #fee2e2; color: #991b1b; }
        .stats-card {
            background: linear-gradient(135deg, #5b8def 0%, #6c63ff 100%);
            color: #ffffff;
            border-radius: 1rem;
            min-height: 150px;
        }
        .stats-card .card-body {
            padding: 1.5rem;
        }
        .leave-progress {
            height: 8px;
            border-radius: 999px;
            background-color: #e9ecef;
            overflow: hidden;
        }
        .leave-progress-bar {
            height: 100%;
            border-radius: 999px;
            transition: width 0.3s ease;
        }
        .leave-progress-good { background-color: #198754; }
        .leave-progress-low { background-color: #ffc107; }
        .leave-progress-exhausted { background-color: #dc3545; }
        .table thead th {
            background: #f1f3f5;
            border-bottom: 0;
        }
        .table-hover tbody tr:hover {
            background: #f8f9fa;
        }
        .page-header-title {
            letter-spacing: -0.025em;
        }
        .quick-action-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            border-radius: 1rem;
            min-height: 130px;
        }
        .quick-action-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.06);
        }
        .avatar-circle {
            width: 40px;
            height: 40px;
            background: #0d6efd;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
        }
    </style>
</head>
<body class="bg-light">
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/dashboard">
                <i class="fas fa-users-cog me-2"></i>
                LeaveManager
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/leave/applications">Approvals</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center text-white">
                    <span class="me-3">Welcome, <strong><%= user.username %></strong></span>
                    <form method="POST" action="/auth/logout" class="d-inline">
                        <button type="submit" class="btn btn-outline-light btn-sm">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <!-- Page Header -->
        <div class="row align-items-center mb-4">
            <div class="col-md-8">
                <h2 class="display-6 fw-bold mb-2">Faculty Leave Details</h2>
                <p class="text-muted mb-1">Comprehensive overview of leave usage for all faculty members in <%= user.department %></p>
                <p class="text-muted small mb-0"><%= currentDate %></p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a href="/dashboard" class="btn btn-outline-secondary btn-lg me-2 mb-2">
                    <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                </a>
                <a href="/leave/applications" class="btn btn-primary btn-lg mb-2">
                    <i class="fas fa-check-circle me-2"></i>Approve Leaves
                </a>
            </div>
        </div>

        <!-- Summary Statistics -->
        <% if (facultyLeaveDetails && facultyLeaveDetails.length > 0) { %>
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-4">
            <div class="col">
                <div class="card stats-card h-100">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase small mb-2 text-white opacity-75">Total Faculty</p>
                            <h3 class="fw-bold text-white mb-0"><%= facultyLeaveDetails.length %></h3>
                        </div>
                        <div class="bg-white bg-opacity-25 p-3 rounded-circle">
                            <i class="fas fa-users text-white fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card stats-card h-100">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase small mb-2 text-white opacity-75">Avg. Leaves Taken</p>
                            <h3 class="fw-bold text-white mb-0"><%= Math.round(facultyLeaveDetails.reduce((sum, f) => sum + f.totalDaysTaken, 0) / facultyLeaveDetails.length) %></h3>
                        </div>
                        <div class="bg-white bg-opacity-25 p-3 rounded-circle">
                            <i class="fas fa-calendar-check text-white fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card stats-card h-100">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase small mb-2 text-white opacity-75">Pending Approvals</p>
                            <h3 class="fw-bold text-white mb-0"><%= facultyLeaveDetails.reduce((sum, f) => sum + f.pendingLeavesCount, 0) %></h3>
                        </div>
                        <div class="bg-white bg-opacity-25 p-3 rounded-circle">
                            <i class="fas fa-clock text-white fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card stats-card h-100">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase small mb-2 text-white opacity-75">Low Balance (&lt; 5 days)</p>
                            <h3 class="fw-bold text-white mb-0"><%= facultyLeaveDetails.filter(f => f.remainingDays <= 5).length %></h3>
                        </div>
                        <div class="bg-white bg-opacity-25 p-3 rounded-circle">
                            <i class="fas fa-exclamation-triangle text-white fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Faculty Leave Details Table -->
        <% if (facultyLeaveDetails && facultyLeaveDetails.length > 0) { %>
        <div class="card shadow-sm overflow-hidden mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">
                    <i class="fas fa-table me-2"></i>Detailed Leave Information
                </h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Faculty Member</th>
                            <th scope="col">Contact</th>
                            <th scope="col">Leave Usage</th>
                            <th scope="col">Pending</th>
                            <th scope="col">Balance Status</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% facultyLeaveDetails.forEach(faculty => { %>
                            <tr>
                                <td class="align-middle py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3">
                                            <%= faculty.username.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <div class="fw-semibold mb-1"><%= faculty.username %></div>
                                            <small class="text-muted">Faculty Member</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="align-middle py-3">
                                    <div class="fw-semibold mb-1">
                                        <a href="mailto:<%= faculty.email %>" class="link-primary">
                                            <%= faculty.email %>
                                        </a>
                                    </div>
                                    <% if (faculty.phone) { %>
                                    <small class="text-muted">
                                        <i class="fas fa-phone me-1"></i><%= faculty.phone %>
                                    </small>
                                    <% } %>
                                </td>
                                <td class="align-middle py-3">
                                    <div class="fw-semibold mb-1"><%= faculty.totalDaysTaken %> days taken</div>
                                    <small class="text-muted d-block mb-2"><%= faculty.approvedLeavesCount %> approved leave<%= faculty.approvedLeavesCount !== 1 ? 's' : '' %></small>
                                    <div class="leave-progress">
                                        <div class="leave-progress-bar <%= faculty.remainingDays > 5 ? 'leave-progress-good' : faculty.remainingDays > 0 ? 'leave-progress-low' : 'leave-progress-exhausted' %>"
                                             style="width: <%= Math.min(100, (faculty.totalDaysTaken / 15) * 100) %>%">
                                        </div>
                                    </div>
                                </td>
                                <td class="align-middle py-3">
                                    <% if (faculty.pendingLeavesCount > 0) { %>
                                        <span class="badge bg-warning text-dark py-2 px-3">
                                            <i class="fas fa-clock me-1"></i>
                                            <%= faculty.pendingLeavesCount %> pending
                                        </span>
                                    <% } else { %>
                                        <span class="badge bg-success py-2 px-3">
                                            <i class="fas fa-check-circle me-1"></i>
                                            None
                                        </span>
                                    <% } %>
                                </td>
                                <td class="align-middle py-3">
                                    <div>
                                        <span class="status-badge <%= faculty.remainingDays > 5 ? 'status-good' : faculty.remainingDays > 0 ? 'status-low' : 'status-exhausted' %>">
                                            <%= faculty.remainingDays %> days left
                                        </span>
                                    </div>
                                    <small class="text-muted d-block mt-1">Annual quota: 15 days</small>
                                </td>
                                <td class="align-middle py-3">
                                    <a href="/leave/faculty/<%= faculty._id %>/history" class="link-primary fw-semibold">
                                        <i class="fas fa-history me-1"></i>View History
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } else { %>
        <!-- No Faculty Found -->
        <div class="card shadow-sm p-5 text-center">
            <div class="mb-4">
                <i class="fas fa-users fa-5x text-muted"></i>
            </div>
            <h3 class="h5 fw-semibold text-muted mb-2">No Faculty Members Found</h3>
            <p class="text-muted mb-4">There are no faculty members in your department or no data is available.</p>
            <a href="/dashboard" class="btn btn-primary btn-lg">
                <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
        <% } %>

        <!-- Quick Actions -->
        <div class="card mt-4">
            <div class="card-body">
                <h5 class="card-title mb-4">
                    <i class="fas fa-bolt me-2"></i>Quick Actions
                </h5>
                <div class="row g-4">
                    <div class="col-md-4">
                        <a href="/leave/applications" class="card quick-action-card h-100 text-decoration-none text-reset p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary text-white rounded-circle p-3 me-3">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0">Approve Leaves</h6>
                                </div>
                            </div>
                            <p class="text-muted mb-0">Review and approve pending leave applications.</p>
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a href="/api/hod/assign-workload" class="card quick-action-card h-100 text-decoration-none text-reset p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-success text-white rounded-circle p-3 me-3">
                                    <i class="fas fa-tasks"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0">Assign Workload</h6>
                                </div>
                            </div>
                            <p class="text-muted mb-0">Manage workload assignments for approved leaves.</p>
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a href="/dashboard" class="card quick-action-card h-100 text-decoration-none text-reset p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-secondary text-white rounded-circle p-3 me-3">
                                    <i class="fas fa-tachometer-alt"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0">Dashboard</h6>
                                </div>
                            </div>
                            <p class="text-muted mb-0">Return to the main dashboard overview.</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>